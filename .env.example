# HELIX Rank — environment variables (copy to .env.local)

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (content + narrative) ---
ANTHROPIC_API_KEY=
CONTENT_MODEL=claude-sonnet-5

# --- Google Search Console (OAuth, read-only) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# --- Keyword data (Semrush primary; DataForSEO cheap alternative) ---
SEMRUSH_API_KEY=
# DATAFORSEO_LOGIN=
# DATAFORSEO_PASSWORD=

# --- GEO / crawlability (reuse helix geo-scan) ---
FIRECRAWL_API_KEY=
# FIRECRAWL_BASE_URL=

# --- Ollama (optional — volume/low-stakes tasks) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3.5:4b

# --- Cron / bot (later phases) ---
DIGEST_SECRET=
# TELEGRAM_BOT_TOKEN=
# META_VERIFY_TOKEN=
# RESEND_API_KEY=
